{
  "name": "hobbyist",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "cd server && node src/index.js",
    "server:dev": "cd server && node --watch src/index.js",
    "db:seed": "cd server && node prisma/seed.js",
    "db:reset": "cd server && npx prisma db push --force-reset && node prisma/seed.js",
    "build": "vite build",
    "build:demo": "VITE_DEMO_MODE=true vite build --base=/hobbyist/",
    "deploy": "npm run build:demo && gh-pages -d dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:server": "cd server && vitest run"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
