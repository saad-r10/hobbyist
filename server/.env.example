# Hobbyist — Server Environment Variables
# Copy this file to .env and fill in values before running

# Server
PORT=3001
NODE_ENV=development

# Security — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=hobbyist-dev-secret-change-in-prod-must-be-32-chars-minimum

# Database
DATABASE_URL="file:./prisma/dev.db"

# CORS — comma-separated list of allowed frontend origins (production)
CLIENT_ORIGIN=https://saad-r10.github.io

# Cover art APIs (optional — omit to disable the respective provider)
# Open Library (books) works without a key.
# TMDB (films): get a free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
# IGDB (games): create a Twitch dev app at https://dev.twitch.tv/console/apps
# then enable IGDB access at https://api.igdb.com
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
