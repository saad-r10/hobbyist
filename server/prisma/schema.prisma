generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  username       String   @unique
  displayName    String
  passwordHash   String
  bio            String   @default("")
  avatarColor    String   @default("#E8A020")
  avatarInitials String
  onboardingDone Boolean  @default(false)
  interests      String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships     ClubMember[]
  posts           Post[]
  replies         Reply[]
  ratings         Rating[]
  chatMessages    ChatMessage[]
  activities      Activity[]
  refreshTokens   RefreshToken[]
  resetTokens     PasswordReset[]
  reactions       Reaction[]
  progress        MemberProgress[]
  personalRatings PersonalRating[]
  notifications       Notification[] @relation("NotificationRecipient")
  notificationsCaused Notification[] @relation("NotificationActor")
}

model Club {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  type        String
  emoji       String   @default("📚")
  accentColor String   @default("#E8A020")
  bgColor     String   @default("#162030")
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      ClubMember[]
  items        ClubItem[]
  posts        Post[]
  chatMessages ChatMessage[]
  notifications Notification[]
}

model ClubMember {
  id       Int      @id @default(autoincrement())
  userId   Int
  clubId   Int
  role     String   @default("member")
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
}

model ClubItem {
  id          Int       @id @default(autoincrement())
  clubId      Int
  title       String
  subtitle    String    @default("")
  description String    @default("")
  coverColor  String    @default("#162030")
  coverUrl    String?
  type        String
  status      String    @default("current")
  dueDate     DateTime?
  eventLabel  String?
  addedAt     DateTime  @default(now())
  finishedAt  DateTime?

  club           Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  ratings        Rating[]
  memberProgress MemberProgress[]
}

model MemberProgress {
  id        Int      @id @default(autoincrement())
  userId    Int
  itemId    Int
  progress  Int      @default(0)
  updatedAt DateTime @updatedAt

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ClubItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model Post {
  id        Int      @id @default(autoincrement())
  clubId    Int
  userId    Int
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club    Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies Reply[]
  notifications Notification[]
}

model Reply {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  text      String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reaction {
  id         Int      @id @default(autoincrement())
  userId     Int
  targetType String   // "post" | "reply" | "chat"
  targetId   Int
  emoji      String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId, emoji])
  @@index([targetType, targetId])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  clubId    Int
  userId    Int
  text      String
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Rating {
  id        Int      @id @default(autoincrement())
  userId    Int
  itemId    Int
  rating    Float
  review    String   @default("")
  createdAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ClubItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model Activity {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String   @default("")
  clubName  String   @default("")
  rating    Float?
  extra     String   @default("{}")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PersonalRating {
  id          Int       @id @default(autoincrement())
  userId      Int
  title       String
  subtitle    String    @default("")
  type        String    // book, film, podcast, game
  rating      Float?
  review      String    @default("")
  source      String    @default("manual") // letterboxd, goodreads, manual
  coverUrl    String?
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, title, type])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      // recipient
  actorId   Int?     // who triggered it
  type      String   // post | reply | like | chat | club_join
  clubId    Int?
  postId    Int?
  count     Int      @default(1) // batching, used by chat
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  club  Club? @relation(fields: [clubId], references: [id], onDelete: Cascade)
  post  Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
